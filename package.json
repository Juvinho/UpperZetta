{
  "name": "upeerzetta",
  "version": "0.1.0",
  "description": "Linguagem Upeerzetta (hibrida, dinamica, web-first)",
  "main": "dist/cli.js",
  "type": "commonjs",
  "bin": {
    "upeerzetta": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "run:example": "npm run build && node dist/cli.js run examples/ola.upz",
    "tokens:example": "npm run build && node dist/cli.js tokens examples/ola.upz"
  },
  "keywords": [
    "language",
    "transpiler",
    "javascript",
    "web"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.8.3"
  }
}
