{
  "name": "zettasource-ide",
  "version": "1.0.0",
  "description": "ZettaSource IDE - Official IDE for UpperZetta (.uz)",
  "main": "src/main/main.js",
  "author": "ZettaSource Team",
  "license": "MIT",
  "scripts": {
    "bundle": "esbuild src/renderer/app.js --bundle --outfile=src/renderer/bundle.js --format=iife --platform=browser --external:electron --external:path --external:fs --external:child_process --external:os",
    "start": "npm run bundle && electron .",
    "build": "npm run bundle && electron-builder --win"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.24.1",
    "@replit/codemirror-vim": "^6.2.1",
    "codemirror": "^6.0.1",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.0"
  }
}
